---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { img } from "../lib/cloudinary";

const teamPhoto = "finished-installation-2_buanra";

const values = [
  {
    title: "Transparency First",
    body: "We show you the real numbers — costs, savings, and contract terms — in plain language before you make any decision.",
  },
  {
    title: "Your Savings, Not Our Commission",
    body: "We recommend the option that saves you the most. Not the option that pays us the most. These should be the same thing — and with us, they are.",
  },
  {
    title: "No Pressure, Ever",
    body: "We present the facts and let you decide. If solar isn't the right fit for your home, we'll tell you that too.",
  },
  {
    title: "Full-Service Support",
    body: "From the first consultation to years of system monitoring, we're your ongoing point of contact — not just a one-time transaction.",
  },
];

const cities = [
  "Miami",
  "Fort Lauderdale",
  "Tampa",
  "Orlando",
  "Jacksonville",
  "Naples",
  "Sarasota",
  "Palm Beach",
  "Gainesville",
  "Tallahassee",
  "Fort Myers",
  "Ocala",
];
---

<Layout
  title="About Purewatt — Florida's Independent Solar Advisor"
  description="Purewatt is Florida's independent solar energy advisor. We're not an installer — we're your advocate, finding the best solar solution for your home at no upfront cost."
>
  <Nav />

  <main>
    <!-- PAGE HERO -->
    <section class="relative bg-ink py-20 md:py-28 overflow-hidden">
      <div class="absolute inset-0 bg-orange-radial opacity-80 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-orange/40 to-transparent"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-xs text-brand-orange font-semibold uppercase tracking-[0.18em] mb-4">
          Who We Are
        </p>
        <h1 class="font-display text-5xl md:text-6xl font-extrabold tracking-tight text-white mb-5">
          About Purewatt
        </h1>
        <p class="text-xl text-white/70 leading-relaxed max-w-2xl mx-auto">
          We're not a solar installer. We're the advisor that helps you find the right one —
          and makes sure you're getting the best deal available.
        </p>
      </div>
    </section>

    <!-- MISSION -->
    <section class="relative bg-white py-20 md:py-28 overflow-hidden">
      <div class="absolute top-20 right-0 w-[500px] h-[500px] bg-orange-radial-soft opacity-50 pointer-events-none" aria-hidden="true"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Text -->
          <div>
            <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-body-text mb-6">
              The Independent Advisor Model
            </h2>
            <p class="text-lg text-muted-text leading-relaxed mb-5">
              When you call a solar company, you're talking to someone who has one product to sell.
              They'll tell you it's the best option available — because it's the only option they have.
            </p>
            <p class="text-lg text-muted-text leading-relaxed mb-5">
              Purewatt is different. We don't install solar. We don't manufacture panels.
              We don't get paid more for recommending one installer over another.
            </p>
            <p class="text-lg text-muted-text leading-relaxed mb-8">
              Our job is to analyze your home and energy costs, survey the options available
              in your area, and match you with the program that genuinely delivers the most savings.
              That's it. That's the entire business model.
            </p>
            <div class="relative bg-ink rounded-2xl p-7 shadow-ink-deep overflow-hidden">
              <div class="absolute top-0 left-0 w-1.5 h-full bg-brand-orange"></div>
              <p class="text-lg font-medium text-white italic leading-relaxed pl-4">
                "We lower your bill. That's the goal. Everything else is just how we get there."
              </p>
            </div>
          </div>

          <!-- Image -->
          <div class="relative rounded-3xl overflow-hidden shadow-ink-deep ring-1 ring-black/5 group">
            <img
              src={img(teamPhoto, 900)}
              alt="Completed Purewatt solar installation on a Florida home"
              class="w-full aspect-[4/3] object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              width="900"
              height="675"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/40 via-transparent to-transparent pointer-events-none"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- VALUES — DARK INK -->
    <section class="relative bg-ink py-20 md:py-28 overflow-hidden">
      <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-orange-radial-soft opacity-50 pointer-events-none" aria-hidden="true"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <p class="text-xs text-brand-orange font-semibold uppercase tracking-widest mb-3">
            How We Work
          </p>
          <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-white">
            What We Stand For
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {values.map((v) => (
            <div class="group bg-white/[0.04] backdrop-blur-sm rounded-2xl border border-white/10 p-8 hover:bg-white/[0.07] hover:border-brand-orange/40 hover:-translate-y-1 transition-all duration-300">
              <div class="w-1 h-8 bg-brand-orange rounded-full mb-5 group-hover:h-10 transition-all duration-300"></div>
              <h3 class="font-semibold text-xl text-white mb-3">{v.title}</h3>
              <p class="text-white/70 leading-relaxed">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- SERVICE AREA -->
    <section class="bg-white py-20 md:py-28 border-t border-border-gray">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-xs text-brand-orange font-semibold uppercase tracking-widest mb-4">
              Where We Operate
            </p>
            <h2 class="font-display text-4xl font-bold tracking-tight text-body-text mb-5">
              We Serve All of Florida
            </h2>
            <p class="text-lg text-muted-text leading-relaxed mb-5">
              From Miami to Jacksonville, Tampa to Orlando, the Panhandle to the Keys —
              our installer network and program access covers every corner of Florida.
            </p>
            <p class="text-lg text-muted-text leading-relaxed">
              Florida's year-round sunshine makes it one of the best states for solar in the country.
              If you're a Florida homeowner, there's a very good chance we can lower your electric bill.
            </p>
          </div>

          <div class="bg-off-white rounded-2xl border border-border-gray p-8 shadow-card hover:shadow-card-hover transition-shadow duration-300">
            <p class="text-[10px] font-bold text-brand-orange uppercase tracking-[0.18em] mb-5">
              Markets We Cover
            </p>
            <div class="grid grid-cols-2 gap-y-3 gap-x-6">
              {cities.map((city) => (
                <span class="text-sm text-body-text flex items-center gap-2 group cursor-default">
                  <span class="w-1.5 h-1.5 rounded-full bg-brand-orange flex-shrink-0 group-hover:scale-150 transition-transform duration-200"></span>
                  <span class="group-hover:text-brand-orange transition-colors duration-200">{city}</span>
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="relative bg-brand-orange py-20 overflow-hidden">
      <div class="absolute top-0 left-0 w-96 h-96 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/5 rounded-full translate-x-1/3 translate-y-1/3" aria-hidden="true"></div>

      <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="font-display text-4xl font-extrabold tracking-tight text-white mb-4">
          Let's Find Your Best Option
        </h2>
        <p class="text-white/85 text-lg mb-8">
          Free, no-obligation analysis. We'll show you exactly what's available for your home.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center bg-white hover:bg-ink text-brand-orange hover:text-white font-bold px-10 py-4 rounded-lg text-lg shadow-ink-deep hover:-translate-y-1 active:translate-y-0 transition-all duration-300 cursor-pointer"
        >
          Get a Free Consultation
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
