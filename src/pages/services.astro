---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { img } from "../lib/cloudinary";

const solarPhoto = "finished-installation-3_ja63dr";
const batteryPhoto = "battery_pqgy0t";

const solarFeatures = [
  "High-efficiency solar panels sized to your home's energy usage",
  "Professional installation by vetted, licensed Florida contractors",
  "System design optimized for your roof angle and sun exposure",
  "Utility interconnection and permit coordination — fully handled",
  "Ongoing system monitoring and maintenance included",
  "No upfront cost in most program structures",
];

const batteryFeatures = [
  "Whole-home backup power — not just a few circuits",
  "Automatic switchover during outages — no manual steps",
  "Stores excess solar energy for use at night or during storms",
  "Real-time energy monitoring via mobile app",
  "Stackable — add capacity for extended backup runtime",
  "Integrates seamlessly with your solar system from day one",
];
---

<Layout
  title="Services — Purewatt | Residential Solar & Battery Storage"
  description="Purewatt offers residential solar and home battery storage for Florida homeowners. No upfront cost, fully maintained, no loan required."
>
  <Nav />

  <main>
    <!-- PAGE HERO -->
    <section class="relative bg-ink py-20 md:py-28 overflow-hidden">
      <div class="absolute inset-0 bg-orange-radial opacity-80 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-orange/40 to-transparent"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-xs text-brand-orange font-semibold uppercase tracking-[0.18em] mb-4">
          What We Offer
        </p>
        <h1 class="font-display text-5xl md:text-6xl font-extrabold tracking-tight text-white mb-5">
          Our Services
        </h1>
        <p class="text-xl text-white/70 leading-relaxed max-w-2xl mx-auto">
          Two solutions designed to lower your energy costs and protect your home
          from Florida's unpredictable grid.
        </p>
      </div>
    </section>

    <!-- RESIDENTIAL SOLAR -->
    <section class="relative bg-white py-20 md:py-28 overflow-hidden">
      <div class="absolute top-20 right-0 w-[500px] h-[500px] bg-orange-radial-soft opacity-50 pointer-events-none" aria-hidden="true"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Text -->
          <div>
            <div class="w-14 h-14 rounded-2xl bg-orange-tint text-brand-orange flex items-center justify-center mb-6 shadow-card">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
              </svg>
            </div>
            <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-body-text mb-5">
              Residential Solar
            </h2>
            <p class="text-lg text-muted-text leading-relaxed mb-8">
              We identify the solar program that fits your home and lifestyle, then match you with the
              installer and structure that delivers the best savings — typically 20–40% off your current
              electric bill, with no upfront cost and no loan required in most cases.
            </p>
            <ul class="space-y-3 mb-8">
              {solarFeatures.map((f) => (
                <li class="flex items-start gap-3">
                  <div class="mt-0.5 w-5 h-5 rounded-full bg-orange-tint text-brand-orange flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="text-body-text text-sm leading-relaxed">{f}</span>
                </li>
              ))}
            </ul>
            <a
              href="/contact"
              class="inline-flex items-center justify-center bg-brand-orange hover:bg-orange-light text-white font-semibold px-8 py-4 rounded-lg shadow-orange-glow hover:shadow-orange-glow-lg transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0 cursor-pointer"
            >
              Get a Free Consultation
              <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
              </svg>
            </a>
          </div>

          <!-- Image -->
          <div class="relative rounded-3xl overflow-hidden shadow-ink-deep ring-1 ring-black/5 group">
            <img
              src={img(solarPhoto, 900)}
              alt="Completed solar panel installation on Florida residential home"
              class="w-full aspect-[4/3] object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              width="900"
              height="675"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/30 via-transparent to-transparent pointer-events-none"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- BATTERY STORAGE — DARK INK -->
    <section class="relative bg-ink py-20 md:py-28 overflow-hidden">
      <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-orange-radial-soft opacity-50 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-orange-radial-soft opacity-40 pointer-events-none" aria-hidden="true"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Image -->
          <div class="order-2 lg:order-1 relative rounded-3xl overflow-hidden shadow-ink-deep ring-1 ring-white/10 group">
            <img
              src={img(batteryPhoto, 800)}
              alt="Home battery backup unit mounted on exterior wall"
              class="w-full aspect-[4/3] object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              width="800"
              height="600"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/40 via-transparent to-transparent pointer-events-none"></div>
          </div>

          <!-- Text -->
          <div class="order-1 lg:order-2">
            <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 text-brand-orange flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M4.5 10.5H18V15H4.5v-4.5zM3.75 18h15A2.25 2.25 0 0021 15.75v-6a2.25 2.25 0 00-2.25-2.25h-15A2.25 2.25 0 001.5 9.75v6A2.25 2.25 0 003.75 18z" />
              </svg>
            </div>
            <span class="inline-block bg-brand-orange/15 text-brand-orange text-xs font-semibold uppercase tracking-widest px-3 py-1.5 rounded-full mb-4 border border-brand-orange/30">
              Available as an Add-On
            </span>
            <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-white mb-5">
              Home Battery<br />Backup &amp; Storage
            </h2>
            <p class="text-lg text-white/75 leading-relaxed mb-5">
              Florida's storms and outages make battery backup a smart investment. A home battery
              stores the energy your solar panels generate and powers your home automatically
              when the grid goes down — no generators, no gas, no noise.
            </p>
            <p class="text-base text-white/65 leading-relaxed mb-8">
              We work with a variety of battery solutions — from compact single-unit setups to
              stackable, whole-home systems — and match each home with the right fit based on
              square footage, outage patterns, and budget.
            </p>
            <ul class="space-y-3 mb-8">
              {batteryFeatures.map((f) => (
                <li class="flex items-start gap-3">
                  <div class="mt-0.5 w-5 h-5 rounded-full bg-brand-orange/20 text-brand-orange flex items-center justify-center flex-shrink-0 border border-brand-orange/30">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="text-white/90 text-sm leading-relaxed">{f}</span>
                </li>
              ))}
            </ul>
            <a
              href="/contact"
              class="inline-flex items-center justify-center bg-brand-orange hover:bg-orange-light text-white font-semibold px-8 py-4 rounded-lg shadow-orange-glow hover:shadow-orange-glow-lg transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0 cursor-pointer"
            >
              Ask About Battery Storage
              <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY USE AN ADVISOR -->
    <section class="bg-off-white py-20 border-t border-border-gray">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-body-text mb-5">
          Why Use an Advisor Instead of Going Direct?
        </h2>
        <p class="text-lg text-muted-text leading-relaxed mb-5">
          When you go directly to an installer, they have one goal: sell you their product.
          When you work with Purewatt, we have one goal: find the program that lowers your bill the most.
        </p>
        <p class="text-lg text-muted-text leading-relaxed mb-10">
          That independence means we compare multiple options, flag unfavorable contract terms,
          and only recommend what genuinely makes financial sense for your home.
        </p>
        <a
          href="/about"
          class="inline-flex items-center gap-2 text-brand-orange hover:text-orange-dark font-semibold text-base transition-all duration-200 cursor-pointer group"
        >
          Learn about our advisory model
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
          </svg>
        </a>
      </div>
    </section>

    <!-- CTA -->
    <section class="relative bg-brand-orange py-20 overflow-hidden">
      <div class="absolute top-0 left-0 w-96 h-96 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/5 rounded-full translate-x-1/3 translate-y-1/3" aria-hidden="true"></div>

      <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="font-display text-4xl md:text-5xl font-extrabold tracking-tight text-white mb-4">
          See What's Right for Your Home
        </h2>
        <p class="text-white/85 text-lg mb-8">
          Free analysis. No obligation. We'll tell you exactly what you qualify for.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center bg-white hover:bg-ink text-brand-orange hover:text-white font-bold px-10 py-4 rounded-lg text-lg shadow-ink-deep hover:-translate-y-1 active:translate-y-0 transition-all duration-300 cursor-pointer"
        >
          Get a Free Consultation
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
