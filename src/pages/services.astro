---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { img } from "../lib/cloudinary";

const solarPhoto =
  "https://images.unsplash.com/photo-1466611653911-95081537e5b7?auto=format&fit=crop&w=900&q=80";
const batteryPhoto =
  "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=800&q=80";

const solarFeatures = [
  "High-efficiency solar panels sized to your home's energy usage",
  "Professional installation by vetted, licensed Florida contractors",
  "System design optimized for your roof angle and sun exposure",
  "Utility interconnection and permit coordination — fully handled",
  "Ongoing system monitoring and maintenance included",
  "No upfront cost in most program structures",
];

const batteryFeatures = [
  "Whole-home backup power — not just a few circuits",
  "Automatic switchover during outages — no manual steps",
  "Stores excess solar energy for use at night or during storms",
  "Real-time energy monitoring via the Tesla app",
  "Stackable — add multiple units for extended backup capacity",
  "Integrates seamlessly with your solar system from day one",
];
---

<Layout
  title="Services — Purewatt | Residential Solar & Tesla Powerwall 3"
  description="Purewatt offers residential solar and Tesla Powerwall 3 battery storage for Florida homeowners. No upfront cost, fully maintained, no loan required."
>
  <Nav />

  <main>
    <!-- PAGE HERO -->
    <section class="bg-off-white py-16 md:py-24 border-b border-border-gray">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-xs text-brand-orange font-semibold uppercase tracking-widest mb-4">
          What We Offer
        </p>
        <h1 class="font-display text-5xl md:text-6xl font-extrabold tracking-tight text-body-text mb-5">
          Our Services
        </h1>
        <p class="text-xl text-muted-text leading-relaxed max-w-2xl mx-auto">
          Two solutions designed to lower your energy costs and protect your home
          from Florida's unpredictable grid.
        </p>
      </div>
    </section>

    <!-- RESIDENTIAL SOLAR -->
    <section class="bg-white py-20 md:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Text -->
          <div>
            <div class="w-12 h-12 rounded-xl bg-orange-tint text-brand-orange flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
              </svg>
            </div>
            <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-body-text mb-5">
              Residential Solar
            </h2>
            <p class="text-lg text-muted-text leading-relaxed mb-8">
              We identify the solar program that fits your home and lifestyle, then match you with the
              installer and structure that delivers the best savings — typically 30–40% off your current
              electric bill, with no upfront cost and no loan required in most cases.
            </p>
            <ul class="space-y-3 mb-8">
              {solarFeatures.map((f) => (
                <li class="flex items-start gap-3">
                  <div class="mt-0.5 w-5 h-5 rounded-full bg-orange-tint text-brand-orange flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="text-body-text text-sm leading-relaxed">{f}</span>
                </li>
              ))}
            </ul>
            <a
              href="/contact"
              class="inline-flex items-center justify-center bg-brand-orange hover:bg-orange-light text-white font-semibold px-8 py-4 rounded-lg transition-colors duration-200"
            >
              Get a Free Analysis
            </a>
          </div>

          <!-- Image -->
          <div class="rounded-2xl overflow-hidden shadow-xl">
            <img
              src={img(solarPhoto, 900)}
              alt="Solar panels on a Florida residential home with blue sky"
              class="w-full aspect-[4/3] object-cover"
              loading="lazy"
              width="900"
              height="675"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- BATTERY STORAGE -->
    <section class="bg-off-white py-20 md:py-28 border-t border-border-gray">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Image -->
          <div class="order-2 lg:order-1 rounded-2xl overflow-hidden shadow-xl">
            <img
              src={img(batteryPhoto, 800)}
              alt="Tesla Powerwall 3 battery storage system installed in a home"
              class="w-full aspect-[4/3] object-cover"
              loading="lazy"
              width="800"
              height="600"
            />
          </div>

          <!-- Text -->
          <div class="order-1 lg:order-2">
            <div class="w-12 h-12 rounded-xl bg-orange-tint text-brand-orange flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M4.5 10.5H18V15H4.5v-4.5zM3.75 18h15A2.25 2.25 0 0021 15.75v-6a2.25 2.25 0 00-2.25-2.25h-15A2.25 2.25 0 001.5 9.75v6A2.25 2.25 0 003.75 18z" />
              </svg>
            </div>
            <span class="inline-block bg-orange-tint text-orange-dark text-xs font-semibold uppercase tracking-widest px-3 py-1.5 rounded-full mb-4">
              Available as an Add-On
            </span>
            <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-body-text mb-5">
              Tesla Powerwall 3<br />Battery Storage
            </h2>
            <p class="text-lg text-muted-text leading-relaxed mb-8">
              Florida's storms and outages make battery backup a smart investment. The Tesla Powerwall 3
              stores the energy your solar panels generate and powers your entire home automatically
              when the grid goes down — no generators, no gas, no noise.
            </p>
            <ul class="space-y-3 mb-8">
              {batteryFeatures.map((f) => (
                <li class="flex items-start gap-3">
                  <div class="mt-0.5 w-5 h-5 rounded-full bg-orange-tint text-brand-orange flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="text-body-text text-sm leading-relaxed">{f}</span>
                </li>
              ))}
            </ul>
            <a
              href="/contact"
              class="inline-flex items-center justify-center bg-brand-orange hover:bg-orange-light text-white font-semibold px-8 py-4 rounded-lg transition-colors duration-200"
            >
              Ask About Battery Storage
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY USE AN ADVISOR -->
    <section class="bg-white py-20 border-t border-border-gray">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-body-text mb-5">
          Why Use an Advisor Instead of Going Direct?
        </h2>
        <p class="text-lg text-muted-text leading-relaxed mb-5">
          When you go directly to an installer, they have one goal: sell you their product.
          When you work with Purewatt, we have one goal: find the program that lowers your bill the most.
        </p>
        <p class="text-lg text-muted-text leading-relaxed mb-10">
          That independence means we compare multiple options, flag unfavorable contract terms,
          and only recommend what genuinely makes financial sense for your home.
        </p>
        <a
          href="/about"
          class="inline-flex items-center gap-2 text-brand-orange hover:text-orange-dark font-semibold text-base transition-colors duration-200"
        >
          Learn about our advisory model
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
          </svg>
        </a>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-brand-orange py-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="font-display text-4xl font-extrabold tracking-tight text-white mb-4">
          See What's Right for Your Home
        </h2>
        <p class="text-white/80 text-lg mb-8">
          Free analysis. No obligation. We'll tell you exactly what you qualify for.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center bg-white hover:bg-off-white text-brand-orange font-bold px-10 py-4 rounded-lg text-lg transition-colors duration-200"
        >
          Get My Free Analysis
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
