---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { img } from "../lib/cloudinary";

const heroPhoto =
  "https://images.unsplash.com/photo-1509391366360-2e959784a276?auto=format&fit=crop&w=900&q=80";
const batteryPhoto =
  "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=800&q=80";

const steps = [
  {
    num: "01",
    title: "We Analyze Your Home",
    body: "Tell us about your home and current energy usage. We review your bill, roof details, and sun exposure to identify your best solar option.",
  },
  {
    num: "02",
    title: "We Source the Right Fit",
    body: "We shop our network of vetted Florida installers and program structures to find the most cost-effective solution for your specific home.",
  },
  {
    num: "03",
    title: "You Start Paying Less",
    body: "Your system is installed, insured, and fully maintained. From day one, you enjoy lower, predictable energy costs with nothing to manage.",
  },
];

const differentiators = [
  {
    title: "Independent Advisor",
    body: "We're not tied to a single installer, product, or financing structure. Our only job is finding the best deal for you.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.745 3.745 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.745 3.745 0 013.296-1.043A3.745 3.745 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.745 3.745 0 013.296 1.043 3.745 3.745 0 011.043 3.296A3.745 3.745 0 0121 12z" /></svg>`,
  },
  {
    title: "No Loan Required",
    body: "Most homeowners qualify for $0 down programs that require no debt and no credit check. You just pay less for electricity.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
  {
    title: "Zero Maintenance",
    body: "Your system is fully maintained and insured. If anything needs repair, we handle it — you have zero operational responsibility.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
  },
  {
    title: "Immediate Savings",
    body: "You see a lower bill from the very first month — not after years of payback. The savings start day one.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  },
  {
    title: "Tesla Powerwall Option",
    body: "Add a Tesla Powerwall 3 for whole-home battery backup. Stay protected from outages and store solar energy for use at night.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M4.5 10.5H18V15H4.5v-4.5zM3.75 18h15A2.25 2.25 0 0021 15.75v-6a2.25 2.25 0 00-2.25-2.25h-15A2.25 2.25 0 001.5 9.75v6A2.25 2.25 0 003.75 18z" /></svg>`,
  },
  {
    title: "All of Florida",
    body: "Wherever you are in Florida — Miami to Jacksonville, Tampa to Orlando — we've got you covered with our installer network.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>`,
  },
];

const testimonials = [
  {
    quote:
      "My bill went from $280 to under $60. I only wish I'd done this sooner. Purewatt made the whole thing effortless.",
    name: "Sarah K.",
    location: "Orlando, FL",
    savings: "$220/mo saved",
    initials: "SK",
  },
  {
    quote:
      "Purewatt handled everything — permits, installation, the utility paperwork. I didn't lift a finger and my electricity bill basically disappeared.",
    name: "Mike R.",
    location: "Tampa, FL",
    savings: "$190/mo saved",
    initials: "MR",
  },
  {
    quote:
      "No loan, no stress, no surprises. My family is saving over $2,400 a year now. Best financial decision we've made for our home.",
    name: "Lisa M.",
    location: "Fort Lauderdale, FL",
    savings: "$200/mo saved",
    initials: "LM",
  },
];

const trustStats = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    stat: "30–40%",
    label: "Average bill reduction",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    stat: "$0",
    label: "Upfront cost",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>`,
    stat: "All FL",
    label: "Statewide coverage",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
    stat: "100%",
    label: "Maintained & insured",
  },
];
---

<Layout title="Purewatt — Lower Your Electric Bill | Florida Solar Advisor">
  <Nav />

  <main>
    <!-- ═══ HERO ═══ -->
    <section class="bg-white pt-14 pb-20 md:pt-20 md:pb-28 overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Text -->
          <div class="order-2 lg:order-1">
            <div class="inline-flex items-center gap-2 bg-orange-tint text-orange-dark text-xs font-semibold px-3 py-1.5 rounded-full mb-6 uppercase tracking-wide">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
              Serving all of Florida
            </div>

            <h1 class="font-display text-[3.25rem] sm:text-[4rem] lg:text-[4.5rem] font-extrabold leading-[1.05] tracking-tight text-body-text mb-6">
              Lower Your<br />
              <span class="text-brand-orange">Electric Bill.</span><br />
              Starting Today.
            </h1>

            <p class="text-lg text-muted-text leading-relaxed mb-8 max-w-lg">
              No upfront cost. No loan required. Purewatt finds the right solar solution
              for your Florida home — and handles everything so you simply pay less.
            </p>

            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href="/contact"
                class="inline-flex items-center justify-center bg-brand-orange hover:bg-orange-light text-white font-semibold px-8 py-4 rounded-lg transition-colors duration-200 text-base"
              >
                Get a Free Analysis
              </a>
              <a
                href="/how-it-works"
                class="inline-flex items-center justify-center border-2 border-body-text text-body-text hover:bg-body-text hover:text-white font-semibold px-8 py-4 rounded-lg transition-colors duration-200 text-base"
              >
                See How It Works
              </a>
            </div>

            <div class="mt-10 flex flex-wrap gap-x-6 gap-y-2 text-sm text-muted-text">
              {["No upfront cost", "No loan required", "Fully maintained"].map((item) => (
                <span class="flex items-center gap-1.5">
                  <svg class="w-4 h-4 text-brand-orange flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                  </svg>
                  {item}
                </span>
              ))}
            </div>
          </div>

          <!-- Image -->
          <div class="order-1 lg:order-2 relative">
            <div class="relative rounded-2xl overflow-hidden shadow-2xl">
              <img
                src={img(heroPhoto, 900)}
                alt="Solar panels installed on a Florida home with clear blue sky"
                class="w-full aspect-[4/3] object-cover"
                loading="eager"
                width="900"
                height="675"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-body-text/20 to-transparent pointer-events-none"></div>
            </div>
            <!-- Floating stat cards -->
            <div class="absolute -bottom-5 -left-4 sm:-left-8 bg-white rounded-xl shadow-xl px-5 py-4 border border-border-gray">
              <p class="text-3xl font-display font-extrabold text-brand-orange leading-none">30–40%</p>
              <p class="text-xs text-muted-text mt-0.5 font-medium">Average bill reduction</p>
            </div>
            <div class="absolute -top-5 -right-4 sm:-right-8 bg-white rounded-xl shadow-xl px-5 py-4 border border-border-gray">
              <p class="text-3xl font-display font-extrabold text-brand-orange leading-none">$0</p>
              <p class="text-xs text-muted-text mt-0.5 font-medium">Upfront cost</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ TRUST BAR ═══ -->
    <section class="bg-off-white py-14 border-y border-border-gray">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4 text-center">
          {trustStats.map((item) => (
            <div class="flex flex-col items-center gap-3">
              <div
                class="w-14 h-14 rounded-full bg-orange-tint text-brand-orange flex items-center justify-center"
                set:html={item.icon}
                aria-hidden="true"
              />
              <p class="text-2xl font-display font-bold text-body-text">{item.stat}</p>
              <p class="text-sm text-muted-text">{item.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ HOW IT WORKS ═══ -->
    <section class="bg-white py-20 md:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="text-xs text-brand-orange font-semibold uppercase tracking-widest mb-3">
            Simple From Start to Savings
          </p>
          <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-body-text mb-4">
            How It Works
          </h2>
          <p class="text-lg text-muted-text max-w-xl mx-auto leading-relaxed">
            Three straightforward steps from your current bill to a lower one.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {steps.map((step) => (
            <div class="bg-white rounded-2xl border border-border-gray p-8 hover:shadow-lg hover:border-orange-tint transition-all duration-300">
              <div class="text-5xl font-display font-extrabold text-orange-tint leading-none mb-6 select-none">
                {step.num}
              </div>
              <h3 class="text-xl font-semibold text-body-text mb-3">{step.title}</h3>
              <p class="text-muted-text leading-relaxed">{step.body}</p>
            </div>
          ))}
        </div>

        <div class="text-center mt-12">
          <a
            href="/how-it-works"
            class="inline-flex items-center gap-2 text-brand-orange hover:text-orange-dark font-semibold text-base transition-colors duration-200"
          >
            See the full process
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ WHY PUREWATT ═══ -->
    <section class="bg-off-white py-20 md:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="text-xs text-brand-orange font-semibold uppercase tracking-widest mb-3">
            What Makes Us Different
          </p>
          <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-body-text mb-4">
            Why Choose Purewatt
          </h2>
          <p class="text-lg text-muted-text max-w-xl mx-auto leading-relaxed">
            We're not a solar company. We're your independent advisor — working for your savings, not a commission.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {differentiators.map((d) => (
            <div class="bg-white rounded-2xl border border-border-gray p-8 hover:shadow-md transition-shadow duration-300">
              <div
                class="w-12 h-12 rounded-xl bg-orange-tint text-brand-orange flex items-center justify-center mb-5"
                set:html={d.icon}
                aria-hidden="true"
              />
              <h3 class="text-lg font-semibold text-body-text mb-2">{d.title}</h3>
              <p class="text-muted-text text-sm leading-relaxed">{d.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ TESTIMONIALS ═══ -->
    <section class="bg-white py-20 md:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="text-xs text-brand-orange font-semibold uppercase tracking-widest mb-3">
            Real Florida Homeowners
          </p>
          <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-body-text">
            What Our Customers Say
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {testimonials.map((t) => (
            <div class="bg-off-white rounded-2xl p-8 flex flex-col">
              <div class="flex gap-1 mb-5" aria-label="5 out of 5 stars">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="w-4 h-4 text-brand-orange" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <blockquote class="text-body-text leading-relaxed flex-1 mb-6">
                &ldquo;{t.quote}&rdquo;
              </blockquote>
              <div class="flex items-center gap-3 pt-5 border-t border-border-gray">
                <div class="w-10 h-10 rounded-full bg-brand-orange flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
                  {t.initials}
                </div>
                <div>
                  <p class="font-semibold text-body-text text-sm">{t.name}</p>
                  <p class="text-muted-text text-xs">{t.location}</p>
                </div>
                <div class="ml-auto">
                  <span class="bg-orange-tint text-orange-dark text-xs font-semibold px-2.5 py-1 rounded-full whitespace-nowrap">
                    {t.savings}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ BATTERY STORAGE ═══ -->
    <section class="bg-off-white py-20 md:py-28 border-y border-border-gray">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Image -->
          <div class="rounded-2xl overflow-hidden shadow-xl">
            <img
              src={img(batteryPhoto, 800)}
              alt="Tesla Powerwall 3 home battery storage system"
              class="w-full aspect-[16/10] object-cover"
              loading="lazy"
              width="800"
              height="500"
            />
          </div>

          <!-- Text -->
          <div>
            <span class="inline-block bg-orange-tint text-orange-dark text-xs font-semibold uppercase tracking-widest px-3 py-1.5 rounded-full mb-5">
              Optional Add-On
            </span>
            <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-body-text mb-5">
              Add Backup Power with<br />
              <span class="text-brand-orange">Tesla Powerwall 3</span>
            </h2>
            <p class="text-lg text-muted-text leading-relaxed mb-8">
              Never worry about outages again. The Tesla Powerwall 3 integrates with your solar system
              to store excess energy and power your entire home automatically when the grid goes down.
            </p>
            <ul class="space-y-4 mb-8">
              {[
                "Whole-home backup power during outages",
                "Automatic switchover — no manual steps",
                "Real-time monitoring via the Tesla app",
                "Maximizes your solar self-consumption",
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <div class="mt-0.5 w-5 h-5 rounded-full bg-orange-tint text-brand-orange flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="text-body-text">{item}</span>
                </li>
              ))}
            </ul>
            <a
              href="/services"
              class="inline-flex items-center gap-2 text-brand-orange hover:text-orange-dark font-semibold text-base transition-colors duration-200"
            >
              Learn about battery storage
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ FINAL CTA ═══ -->
    <section class="bg-brand-orange py-20 md:py-28">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-display text-4xl md:text-5xl font-extrabold tracking-tight text-white mb-5">
          Ready to Lower Your Bill?
        </h2>
        <p class="text-white/80 text-lg leading-relaxed mb-8">
          See exactly how much your home could save. Your free analysis takes less than 5 minutes
          and there's absolutely no obligation.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center bg-white hover:bg-off-white text-brand-orange font-bold px-10 py-4 rounded-lg text-lg transition-colors duration-200 shadow-lg"
        >
          Get My Free Analysis
        </a>
        <p class="text-white/60 text-sm mt-5">
          No loan applications. No hard credit pulls. No pressure.
