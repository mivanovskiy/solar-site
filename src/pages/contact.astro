---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Get a Free Consultation — Purewatt"
  description="Request your free solar consultation. No upfront cost, no obligation. Purewatt will show you exactly how much your Florida home could save on electricity."
>
  <Nav />

  <main>
    <!-- PAGE HERO -->
    <section class="relative bg-ink py-20 md:py-24 overflow-hidden">
      <div class="absolute inset-0 bg-orange-radial opacity-80 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-orange/40 to-transparent"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-xs text-brand-orange font-semibold uppercase tracking-[0.18em] mb-4">
          Free, No Obligation
        </p>
        <h1 class="font-display text-5xl md:text-6xl font-extrabold tracking-tight text-white mb-5">
          Get Your Free Consultation
        </h1>
        <p class="text-xl text-white/70 leading-relaxed max-w-2xl mx-auto">
          Tell us about your home and we'll show you exactly how much you could save.
          Takes less than 5 minutes. We'll be in touch within 24 hours.
        </p>
      </div>
    </section>

    <!-- FORM + SIDEBAR -->
    <section class="bg-white py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

          <!-- Form column -->
          <div class="lg:col-span-7">

            <!-- The form — visible by default, hidden after success -->
            <form
              id="contact-form"
              name="contact"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              class="space-y-6"
              novalidate
            >
              <input type="hidden" name="form-name" value="contact" />
              <p class="hidden" aria-hidden="true">
                <label>
                  Don't fill this out:
                  <input name="bot-field" tabindex="-1" autocomplete="off" />
                </label>
              </p>

              <!-- Full name -->
              <div>
                <label for="full-name" class="block text-sm font-semibold text-body-text mb-1.5">
                  Full Name <span class="text-brand-orange" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="full-name"
                  name="full-name"
                  required
                  autocomplete="name"
                  placeholder="Jane Smith"
                  class="w-full border border-border-gray rounded-lg px-4 py-3 text-body-text placeholder:text-muted-text focus:outline-none focus:ring-2 focus:ring-brand-orange focus:border-transparent text-base transition"
                />
              </div>

              <!-- Email + Phone -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="email" class="block text-sm font-semibold text-body-text mb-1.5">
                    Email Address <span class="text-brand-orange" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
                    placeholder="jane@example.com"
                    class="w-full border border-border-gray rounded-lg px-4 py-3 text-body-text placeholder:text-muted-text focus:outline-none focus:ring-2 focus:ring-brand-orange focus:border-transparent text-base transition"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-semibold text-body-text mb-1.5">
                    Phone Number <span class="text-brand-orange" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    autocomplete="tel"
                    placeholder="(555) 000-0000"
                    class="w-full border border-border-gray rounded-lg px-4 py-3 text-body-text placeholder:text-muted-text focus:outline-none focus:ring-2 focus:ring-brand-orange focus:border-transparent text-base transition"
                  />
                </div>
              </div>

              <!-- City / ZIP -->
              <div>
                <label for="city-zip" class="block text-sm font-semibold text-body-text mb-1.5">
                  City / ZIP Code <span class="text-brand-orange" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="city-zip"
                  name="city-zip"
                  required
                  autocomplete="postal-code"
                  placeholder="Tampa, FL 33602"
                  class="w-full border border-border-gray rounded-lg px-4 py-3 text-body-text placeholder:text-muted-text focus:outline-none focus:ring-2 focus:ring-brand-orange focus:border-transparent text-base transition"
                />
              </div>

              <!-- Monthly bill -->
              <div>
                <label for="monthly-bill" class="block text-sm font-semibold text-body-text mb-1.5">
                  Current Monthly Electric Bill <span class="text-brand-orange" aria-hidden="true">*</span>
                </label>
                <select
                  id="monthly-bill"
                  name="monthly-bill"
                  required
                  class="w-full border border-border-gray rounded-lg px-4 py-3 text-body-text bg-white focus:outline-none focus:ring-2 focus:ring-brand-orange focus:border-transparent text-base transition appearance-none cursor-pointer"
                >
                  <option value="" disabled selected>Select your range</option>
                  <option value="under-100">Under $100</option>
                  <option value="100-200">$100 – $200</option>
                  <option value="200-300">$200 – $300</option>
                  <option value="300-plus">$300+</option>
                </select>
              </div>

              <!-- Referral (optional) -->
              <div>
                <label for="referral" class="block text-sm font-semibold text-body-text mb-1.5">
                  How did you hear about us?
                  <span class="text-muted-text font-normal">(optional)</span>
                </label>
                <input
                  type="text"
                  id="referral"
                  name="referral"
                  placeholder="Google, referral, social media…"
                  class="w-full border border-border-gray rounded-lg px-4 py-3 text-body-text placeholder:text-muted-text focus:outline-none focus:ring-2 focus:ring-brand-orange focus:border-transparent text-base transition"
                />
              </div>

              <!-- Submit -->
              <button
                type="submit"
                id="submit-btn"
                class="w-full bg-brand-orange hover:bg-orange-light text-white font-bold py-4 px-8 rounded-lg text-base shadow-orange-glow hover:shadow-orange-glow-lg transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0 flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed cursor-pointer"
              >
                <span id="btn-text">Get My Free Consultation</span>
                <span id="btn-loading" class="hidden" aria-live="polite">
                  <svg class="w-5 h-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                  Submitting…
                </span>
              </button>

              <p class="text-xs text-muted-text text-center">
                We never share or sell your information. No spam, ever.
              </p>
            </form>

            <!-- Success state — hidden until form submitted -->
            <div id="success-state" class="hidden text-center py-16" role="status" aria-live="polite">
              <div class="w-16 h-16 rounded-full bg-orange-tint text-brand-orange flex items-center justify-center mx-auto mb-5 shadow-orange-glow">
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </div>
              <h3 class="font-display text-3xl font-bold text-body-text mb-3">You're All Set!</h3>
              <p class="text-lg text-muted-text max-w-sm mx-auto leading-relaxed">
                We'll be in touch within <strong class="text-body-text">24 hours</strong> with your
                personalized savings analysis.
              </p>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="lg:col-span-5 space-y-6">

            <!-- What happens next -->
            <div class="bg-off-white rounded-2xl border border-border-gray p-8 shadow-card">
              <h3 class="font-semibold text-lg text-body-text mb-5">What happens after you submit:</h3>
              <ol class="space-y-4">
                {[
                  "We review your bill range and home location within 24 hours.",
                  "We call or email to schedule a 15-minute consultation.",
                  "We present your personalized savings estimate — no obligation.",
                ].map((text, i) => (
                  <li class="flex items-start gap-3">
                    <span class="w-6 h-6 rounded-full bg-brand-orange text-white text-xs font-bold flex items-center justify-center flex-shrink-0 mt-0.5 shadow-orange-glow">
                      {i + 1}
                    </span>
                    <span class="text-muted-text text-sm leading-relaxed">{text}</span>
                  </li>
                ))}
              </ol>
            </div>

            <!-- Contact info -->
            <div class="bg-ink rounded-2xl border border-white/10 p-8 shadow-ink-deep">
              <h3 class="font-semibold text-lg text-white mb-5">Prefer to talk first?</h3>
              <div class="space-y-4">
                <a
                  href="tel:+18136036813"
                  class="group flex items-center gap-3 text-white hover:text-brand-orange transition-colors duration-200 cursor-pointer"
                >
                  <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 text-brand-orange flex items-center justify-center flex-shrink-0 group-hover:bg-brand-orange group-hover:text-white group-hover:border-brand-orange transition-all duration-300">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-semibold">(813) 603-6813</p>
                    <p class="text-xs text-white/50">Mon–Fri, 8am–6pm ET</p>
                  </div>
                </a>

                <a
                  href="mailto:info@purewatt.solar"
                  class="group flex items-center gap-3 text-white hover:text-brand-orange transition-colors duration-200 cursor-pointer"
                >
                  <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 text-brand-orange flex items-center justify-center flex-shrink-0 group-hover:bg-brand-orange group-hover:text-white group-hover:border-brand-orange transition-all duration-300">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-semibold">info@purewatt.solar</p>
                    <p class="text-xs text-white/50">We reply within 24 hours</p>
                  </div>
                </a>
              </div>
            </div>

            <!-- Trust badge -->
            <div class="bg-orange-tint rounded-2xl border border-brand-orange/20 p-6 flex items-start gap-4 shadow-card">
              <div class="w-10 h-10 rounded-lg bg-white text-brand-orange flex items-center justify-center flex-shrink-0 shadow-card">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-sm text-body-text mb-1">100% Free, No Commitment</p>
                <p class="text-xs text-muted-text leading-relaxed">
                  Your consultation is completely free. No hard credit pulls, no loan applications,
                  no pressure to move forward.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const successState = document.getElementById("success-state");
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const btnText = document.getElementById("btn-text");
  const btnLoading = document.getElementById("btn-loading");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    btnText?.classList.add("hidden");
    btnLoading?.classList.remove("hidden");
    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch("/", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: new URLSearchParams(
          new FormData(form) as unknown as Record<string, string>
        ).toString(),
      });

      if (res.ok) {
        form.classList.add("hidden");
        successState?.classList.remove("hidden");
        successState?.scrollIntoView({ behavior: "smooth", block: "center" });
      } else {
        throw new Error("Non-OK response");
      }
    } catch {
      // Fall back to native form submit so the lead is never lost
      btnText?.classList.remove("hidden");
      btnLoading?.classList.add("hidden");
      if (submitBtn) submitBtn.disabled = false;
      form.submit();
    }
  });
</script>
