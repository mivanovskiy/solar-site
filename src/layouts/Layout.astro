---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Purewatt — Lower Your Electric Bill",
  description = "Florida's independent solar energy advisor. No upfront cost, no loan required. Get your free savings analysis today.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <link rel="icon" type="image/png" href="/images/logos/purewatt-logo-icon.png" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- DM Sans + Barlow Condensed — font-display:swap prevents render blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="font-sans text-body-text antialiased">
    <slot />
  </body>
</html>
