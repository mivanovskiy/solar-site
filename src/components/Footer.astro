---
const year = new Date().getFullYear();

const links = [
  { href: "/", label: "Home" },
  { href: "/how-it-works", label: "How It Works" },
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<footer class="bg-dark-gray text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 lg:gap-16">

      <!-- Brand column -->
      <div class="md:col-span-5">
        <a href="/" aria-label="Purewatt homepage">
          <img
            src="/images/logos/purewatt-logo-horizontal.png"
            alt="Purewatt"
            class="h-9 w-auto brightness-0 invert mb-5"
            width="180"
            height="36"
          />
        </a>
        <p class="text-white/65 text-sm leading-relaxed max-w-xs">
          Florida's independent solar energy advisor. We lower your electric bill
          with no upfront cost, no loan required, and no maintenance responsibility.
        </p>
        <div class="mt-6 pt-6 border-t border-white/10">
          <p class="text-xs text-white/40 uppercase tracking-widest font-medium mb-1.5">Service Area</p>
          <p class="text-white/65 text-sm">All of Florida</p>
        </div>
      </div>

      <!-- Pages column -->
      <div class="md:col-span-3 md:col-start-7">
        <p class="text-xs text-white/40 uppercase tracking-widest font-medium mb-5">Pages</p>
        <ul class="space-y-3">
          {links.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-white/65 hover:text-white text-sm transition-colors duration-200"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div class="md:col-span-4">
        <p class="text-xs text-white/40 uppercase tracking-widest font-medium mb-5">Contact</p>
        <ul class="space-y-3 text-sm text-white/65">
          <li>
            <a
              href="tel:+18007873928"
              class="hover:text-white transition-colors duration-200"
            >
              (800) 787-3928
            </a>
          </li>
          <li>
            <a
              href="mailto:hello@purewatt.com"
              class="hover:text-white transition-colors duration-200"
            >
              hello@purewatt.com
            </a>
          </li>
          <li>Florida, USA</li>
        </ul>
        <a
          href="/contact"
          class="mt-6 inline-flex items-center bg-brand-orange hover:bg-orange-light text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors duration-200"
        >
          Get a Free Quote
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/35">
      <p>&copy; {year} Purewatt LLC. All rights reserved.</p>
      <p>Solar energy brokerage &amp; consulting &mdash; Florida</p>
    </div>
  </div>
</footer>
