---
const year = new Date().getFullYear();

const links = [
  { href: "/", label: "Home" },
  { href: "/how-it-works", label: "How It Works" },
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<footer class="relative bg-ink text-white overflow-hidden">
  <!-- Top accent bar -->
  <div class="h-1 w-full bg-gradient-to-r from-brand-orange via-orange-light to-brand-orange"></div>

  <!-- Subtle orange glow -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-orange-radial-soft opacity-60 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 lg:gap-16">

      <!-- Brand column -->
      <div class="md:col-span-5">
        <a href="/" aria-label="Purewatt homepage" class="inline-block transition-transform duration-300 hover:scale-[1.02]">
          <img
            src="/images/logos/purewatt-logo-horizontal.png"
            alt="Purewatt"
            class="h-9 w-auto brightness-0 invert mb-6"
            width="180"
            height="36"
          />
        </a>
        <p class="text-white/70 text-sm leading-relaxed max-w-xs">
          Florida's independent solar energy advisor. We lower your electric bill
          with no upfront cost, no loan required, and no maintenance responsibility.
        </p>
        <div class="mt-7 pt-6 border-t border-white/10">
          <p class="text-[10px] text-brand-orange uppercase tracking-[0.18em] font-bold mb-2">Service Area</p>
          <p class="text-white/80 text-sm font-medium">All of Florida</p>
        </div>
      </div>

      <!-- Pages column -->
      <div class="md:col-span-3 md:col-start-7">
        <p class="text-[10px] text-brand-orange uppercase tracking-[0.18em] font-bold mb-5">Pages</p>
        <ul class="space-y-3">
          {links.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-white/65 hover:text-white text-sm transition-all duration-200 hover:translate-x-0.5 inline-flex cursor-pointer"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div class="md:col-span-4">
        <p class="text-[10px] text-brand-orange uppercase tracking-[0.18em] font-bold mb-5">Contact</p>
        <ul class="space-y-3 text-sm text-white/65">
          <li>
            <a
              href="tel:+18136036813"
              class="hover:text-brand-orange transition-colors duration-200 cursor-pointer"
            >
              (813) 603-6813
            </a>
          </li>
          <li>
            <a
              href="mailto:info@purewatt.solar"
              class="hover:text-brand-orange transition-colors duration-200 cursor-pointer"
            >
              info@purewatt.solar
            </a>
          </li>
          <li>
            <a
              href="https://purewatt.solar"
              class="hover:text-brand-orange transition-colors duration-200 cursor-pointer"
            >
              purewatt.solar
            </a>
          </li>
          <li class="text-white/50">Florida, USA</li>
        </ul>
        <a
          href="/contact"
          class="mt-7 inline-flex items-center bg-brand-orange hover:bg-orange-light text-white text-sm font-semibold px-5 py-2.5 rounded-lg shadow-orange-glow hover:shadow-orange-glow-lg transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0 cursor-pointer"
        >
          Get a Free Consultation
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-14 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/40">
      <p>&copy; {year} Purewatt LLC. All rights reserved.</p>
      <p>Solar energy brokerage &amp; consulting &mdash; Florida</p>
    </div>
  </div>
</footer>
